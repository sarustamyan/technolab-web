@model Technolab.OnlineLibrary.Web.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Login";
}

<h1 class="display-4 mb-6">Forgot Password</h1>

@if (ViewBag.EmailSent)
{    
    <h2>Email has been sent.</h2>
}
else
{
    <div class="row">
        <div class="col-md-6">
            <form method="post">
                <div class="mb-3">
                    <label asp-for="Username" class="form-label"></label>
                    <input asp-for="Username" class="form-control" />
                    <span asp-validation-for="Username" class="form-text invalid-feedback"></span>
                </div>
                <div class="mb-3">
                    <button type="submit" class="btn btn-primary">Reset Password</button>
                </div>
            </form>
        </div>
    </div>
}

